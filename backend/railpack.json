{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20"
  },
  "steps": {
    "install": {
      "commands": ["npm ci"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["npx prisma generate", "npm run build"]
    }
  },
  "deploy": {
    "startCommand": "npx prisma migrate deploy && node dist/index.js"
  }
}
