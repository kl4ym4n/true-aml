// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BlacklistCategory {
  SCAM
  SANCTION
  STOLEN_FUNDS
  RANSOM
  DARK_MARKET
  MIXER
  EXCHANGE
  PHISHING
  SUSPICIOUS
}

enum EntityType {
  exchange
  mixer
  bridge
  lp
  unknown
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CrawlQueueStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum CrawlSeedKind {
  DIRECT_STRONG
  DERIVED_SUSPICIOUS
  OBSERVED_LOW
}

// Blacklisted addresses known for illicit activities
model BlacklistedAddress {
  id         String            @id @default(uuid())
  address    String            @unique @db.VarChar(42)
  category   BlacklistCategory
  riskScore  Int               @default(0)
  confidence Float             @default(0.0)
  /// Legacy single-line summary; prefer sourcesJson for provenance.
  source     String            @db.Text
  /// Hop depth from expansion root (0 = seed / non-derived).
  depth      Int               @default(0)
  /// Optional entity class (exchange/mixer/…); category remains AML bucket for now.
  entityType EntityType?
  /// Structured provenance: [{ name, type, firstSeenAt, confidenceContribution?, … }]
  sourcesJson Json?
  isDerived  Boolean           @default(false)
  derivedFrom String?          @db.VarChar(255)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([address])
  @@index([category])
  @@index([riskScore])
  @@index([confidence])
  @@index([isDerived])
  @@index([depth])
  @@map("blacklisted_addresses")
}

// Profile information for tracked addresses
model AddressProfile {
  id           String    @id @default(uuid())
  address      String    @unique @db.VarChar(42)
  firstSeenAt  DateTime
  txCount      Int       @default(0)
  lastCheckedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([address])
  @@index([lastCheckedAt])
  @@map("address_profiles")
}

/// BFS-style graph crawl scheduling (TRON today; `chain` reserved for multi-chain).
model CrawlQueue {
  id                  String           @id @default(uuid())
  address             String           @db.VarChar(42)
  chain               String           @default("tron") @db.VarChar(32)
  status              CrawlQueueStatus @default(PENDING)
  seedKind            CrawlSeedKind    @default(OBSERVED_LOW)
  priority            Float            @default(0)
  /// Minimum hops from a high-confidence risky seed when this URL was enqueued.
  hopFromRiskyRoot    Int              @default(0)
  nextRunAt           DateTime         @default(now())
  lastRunAt           DateTime?
  lastCompletedAt     DateTime?
  consecutiveFailures Int              @default(0)
  lastError           String?          @db.Text
  lockedAt            DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@unique([address, chain])
  @@index([status, nextRunAt])
  @@index([priority(sort: Desc)])
  @@map("crawl_queue")
}

/// Directed exposure edge root → counterparty from crawler observation.
model AddressEdge {
  id                  String   @id @default(uuid())
  rootAddress         String   @db.VarChar(42)
  counterpartyAddress String   @db.VarChar(42)
  chain               String   @default("tron") @db.VarChar(32)
  totalVolume         Float    @default(0)
  txCount             Int      @default(0)
  share               Float?
  lastObservedAt      DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([rootAddress, counterpartyAddress, chain])
  @@index([counterpartyAddress])
  @@map("address_edges")
}

/// Aggregated graph-derived signal before conservative promotion to `BlacklistedAddress`.
model CandidateSignal {
  id                       String      @id @default(uuid())
  address                  String      @unique @db.VarChar(42)
  chain                    String      @default("tron") @db.VarChar(32)
  aggregatedConfidence     Float       @default(0)
  minHopToRiskyRoot        Int         @default(999)
  interactionCount         Int         @default(0)
  totalRiskVolume          Float       @default(0)
  uniqueCounterpartyCount  Int         @default(0)
  maxObservedShare         Float       @default(0)
  primaryRootAddress       String?     @db.VarChar(42)
  hopDepth                 Int         @default(0)
  entityType               EntityType?
  isInfrastructure         Boolean     @default(false)
  sourcesJson              Json?
  promotedAt               DateTime?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@index([aggregatedConfidence])
  @@index([promotedAt])
  @@index([isInfrastructure])
  @@map("candidate_signals")
}

// Transaction risk assessment results
model TransactionCheck {
  id         String     @id @default(uuid())
  txHash     String     @db.VarChar(64)
  riskScore  Int        @default(0)
  riskLevel  RiskLevel
  flags      String[]
  createdAt  DateTime   @default(now())

  @@index([txHash])
  @@index([riskLevel])
  @@index([riskScore])
  @@index([createdAt])
  @@map("transaction_checks")
}


