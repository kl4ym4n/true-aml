# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=true_aml
POSTGRES_PORT=5432

# Backend Configuration
TRONGRID_API_KEY=your_trongrid_api_key_here
API_KEY=your_api_key_here
# Comma-separated allowed CORS origins (empty = allow all in dev). Example: https://app.yourdomain.com
ALLOWED_ORIGINS=

# Frontend Configuration (for dev mode)
# NEXT_PUBLIC_API_BASE_URL is set in docker-compose files

# Graph crawler (optional; TRON graph BFS + conservative SUSPICIOUS promotion)
# CRAWLER_ENABLED=false
# CRAWLER_BATCH_SIZE=100
# CRAWLER_CONCURRENCY=4
# CRAWLER_MAX_HOP=2
# CRAWLER_DIRECT_RECRAWL_HOURS=6
# CRAWLER_DERIVED_RECRAWL_HOURS=24
# CRAWLER_LOW_CONFIDENCE_RECRAWL_HOURS=48
# CRAWLER_PROMOTION_THRESHOLD=0.2
# CRAWLER_PROMOTION_MAX_DEPTH=2
# CRAWLER_MIN_PROMOTION_VOLUME=50
# CRAWLER_MIN_EDGE_VOLUME=50
# CRAWLER_MIN_EDGE_SHARE=0.03
# CRAWLER_CRON=*/30 * * * *
# CRAWLER_ENQUEUE_AFTER_INGESTION=true
# CRAWLER_ENQUEUE_FROM_EXPANSION=false
# CRAWLER_FAILURE_BACKOFF_BASE_MINUTES=15
# CRAWLER_FAILURE_BACKOFF_MAX_MINUTES=720
# CRAWLER_STALE_LOCK_MINUTES=30
